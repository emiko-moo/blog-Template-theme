# ==========================================
# OS・エディタが自動生成する不要ファイル
# ==========================================
.DS_Store
Thumbs.db
Desktop.ini

# エディタの個人設定（他人が開いたときに邪魔になります）
.vscode/
.idea/
*.suo
*.workspace

# ==========================================
# バックアップ・一時ファイル
# ==========================================
*.bak
*.tmp
*.log
*~

# ==========================================
# 開発ツール・コンパイル関連（使う場合のみ自動除外）
# ==========================================
node_modules/
.sass-cache/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
